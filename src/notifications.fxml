<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.musictick.controller.NotificationsController">
    <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>
    <Label text="Ειδοποιήσεις" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    <ListView fx:id="alertsListView" prefWidth="650" prefHeight="350"/>
    <Label fx:id="statusLabel" textFill="#2c3e50"/>
    <Button text="Refresh" onAction="#checkNewAlerts"/>
    <Button text="Πίσω" onAction="#goBack"/>
</VBox>
