<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.musictick.controller.TransferTicketController">
    <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>
    <Label text="Μεταβίβαση Εισιτηρίου" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    <ComboBox fx:id="ticketComboBox" promptText="Επίλεξε εισιτήριο" prefWidth="420"/>
    <TextField fx:id="recipientEmailField" promptText="Email παραλήπτη" prefWidth="420"/>
    <Button text="Μεταβίβαση" onAction="#submitRecipientData"/>
    <Label fx:id="messageLabel" textFill="red"/>
    <Button text="Πίσω" onAction="#goBack"/>
</VBox>
