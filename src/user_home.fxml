<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/8" fx:controller="com.musictick.HomeController">
    <left>
        <VBox spacing="15" style="-fx-background-color: #2c3e50; -fx-min-width: 200;">
            <padding>
                <Insets bottom="20" left="10" right="10" top="20" />
            </padding>
            <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="MusicTick Menu" />
            <Separator />

            <Button maxWidth="Infinity" onAction="#handleConcerts" style="-fx-background-color: #34495e; -fx-text-fill: white;" text="Concerts" />
            <Button maxWidth="Infinity" onAction="#handleTickets" style="-fx-background-color: #34495e; -fx-text-fill: white;" text="My Tickets" />
            <Button maxWidth="Infinity" onAction="#handleForum" style="-fx-background-color: #34495e; -fx-text-fill: white;" text="Forum" />
            <Button maxWidth="Infinity" onAction="#handleReport" style="-fx-background-color: #34495e; -fx-text-fill: white;" text="Report Problem" />
            <Button maxWidth="Infinity" onAction="#handleTransferTicket" style="-fx-background-color: #34495e; -fx-text-fill: white;" text="Transfer Ticket" />
            <Button maxWidth="Infinity" onAction="#handleNotifications" style="-fx-background-color: #34495e; -fx-text-fill: white;" text="Notifications" />

            

            <Region VBox.vgrow="ALWAYS" />
            <Button maxWidth="Infinity" onAction="#handleLogout" style="-fx-background-color: #c0392b; -fx-text-fill: white;" text="Logout" />
        </VBox>
    </left>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #ecf0f1;">
            <VBox spacing="25">
                <padding>
                    <Insets bottom="40" left="40" right="40" top="40" />
                </padding>

                <VBox spacing="5">
                    <Label style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Καλώς ήρθατε στο Neon Rhythm!" />
                    <Label style="-fx-font-size: 16px; -fx-text-fill: #7f8c8d;" text="Η δική σας πύλη για τον κόσμο των συναυλιών." />
                </VBox>

                <Separator />

                <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2980b9;" text="Τι μπορείτε να κάνετε στην εφαρμογή;" />

                <VBox spacing="20">
                    <HBox alignment="CENTER_LEFT" spacing="15">
                         <Label style="-fx-font-size: 24px;" text="🔎" />
                         <VBox>
                             <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;" text="Προηγμένη Αναζήτηση" />
                             <Label text="Βρείτε άμεσα τους αγαπημένους σας καλλιτέχνες." />
                         </VBox>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="15">
                         <Label style="-fx-font-size: 24px;" text="🎟️" />
                         <VBox>
                             <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;" text="Αγορά &amp; Μεταβίβαση" />
                             <Label text="Ασφαλής αγορά εισιτηρίων." />
                         </VBox>
                    </HBox>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />
                <Label style="-fx-font-style: italic; -fx-text-fill: #95a5a6;" text="Επιλέξτε μια κατηγορία από το μενού αριστερά." />
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
